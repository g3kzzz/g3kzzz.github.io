---
layout: null
permalink: /assets/posts.json
---
{
  "generated_at": "{{ "now" | date_to_xmlschema }}",
  "posts": [
    {% for p in site.posts %}
    {
      "title": {{ p.title | jsonify }},
      "url": {{ p.url | relative_url | jsonify }},
      "date_raw": "{{ p.date | date: "%Y-%m-%d" }}",
      "date_pretty": "{{ p.date | date: "%b %-d, %Y" }}",
      "reading_time": {{ p.reading_time | default: "5 min" | jsonify }},
      "tags": {{ p.tags | jsonify }},
      "categories": {{ p.categories | jsonify }},
      "cover": {{ p.cover | relative_url | jsonify }},
      "summary": {{ p.summary | jsonify }}
    }{% if forloop.last == false %},{% endif %}
    {% endfor %}
  ]
}
